Insight_HtmlServiceUrl=https://insight-web/WcfDataService/HtmlDataService.svc
Insight_ViewerUrl=https://insight-web/View/Default.aspx
ChartSnapshot_Insight.Pdf.AdditionalArguments=--no-sandbox
Insight_MachineDecryptionKey="<GENERATE_MACHINE_KEY>"
Insight_MachineValidationKey="<GENERATE_MACHINE_KEY>"
Scheduler_Login=Administrator
