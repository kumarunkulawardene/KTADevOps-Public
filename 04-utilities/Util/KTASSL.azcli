curl.exe -K -H "Host:analytics.customer.example.com" "https://localhost" -v

(Get-Content .\ImportSSLCert.ps1 ).Replace('WebHosting','My') | Out-File c:\kta\ImportSSLCert.ps1



Get-WebBinding -Port 443 -Name "Default Web Site" | Remove-WebBinding

$iisWebsiteName="Default Web Site"
$thumbprints = Get-ChildItem -path cert:\LocalMachine\WebHosting;
$binding1 = Get-WebBinding -Name $iisWebsiteName -Port 443 -Protocol "https";
$binding1.AddSslCertificate($thumbprints[0].Thumbprint, "My");

$rootStore = New-Object System.Security.Cryptography.X509Certificates.X509Store -ArgumentList Root, LocalMachine
$rootStore.Open("MaxAllowed")
$rootStore.Add($cert)
$rootStore.Close()

cd iis:
new-item -path IIS:\SslBindings\0.0.0.0!443 -value $cert
New-WebBinding -Name "Default Web Site" -IP "*" -Port 443 -Protocol https
iisreset


